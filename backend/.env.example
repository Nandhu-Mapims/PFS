PORT=5000
MONGODB_URI=mongodb://localhost:27017/feedbacksystem

# Initial admin/staff + 100+ hospital departments (run: npm run seed). Change passwords before production.
SEED_ADMIN_USERNAME=admin
SEED_STAFF_USERNAME=staff
SEED_ADMIN_PASSWORD=admin123
SEED_STAFF_PASSWORD=staff123

# Sarvam — speech-to-text for voice feedback (optional)
# https://dashboard.sarvam.ai/ — key must never be exposed to the browser
SARVAM_API_KEY=
# Optional: saaras:v3 (default) or saarika:v2.5
# SARVAM_STT_MODEL=saaras:v3
# For saaras:v3: transcribe | translate | verbatim | translit | codemix
# SARVAM_STT_MODE=codemix

# Groq — AI analysis on each new feedback (optional)
# https://console.groq.com/keys
GROQ_API_KEY=
# Optional override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.1-8b-instant

# ---------------------------------------------------------------------------
# TMS (Ticket Management System) direct DB integration
# ---------------------------------------------------------------------------
# Feedback now inserts tickets directly into TMS MongoDB (no TMS API URL,
# service-account empId, password, or department-id mapping needed).
# A dedicated TMS section/category named "Feedback Tickets" is auto-created,
# and feedback AI department output is used as the subcategory.
#
# Optional: override TMS Mongo URI.
# Default if omitted: mongodb://127.0.0.1:27017/tms_hospital
# TMS_MONGODB_URI=mongodb://127.0.0.1:27017/tms_hospital

# Optional: TMS web app URL — used to build clickable links in the admin UI.
# TMS_CLIENT_URL=http://localhost:8090
