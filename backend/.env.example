PORT=5000

MONGODB_URI=mongodb://localhost:27017/feedbacksystem

# Clear DB and load demo departments, services, and sample feedback:
#   npm run seed-mock -- --yes
SEED_ADMIN_USERNAME=admin
SEED_STAFF_USERNAME=staff
SEED_ADMIN_PASSWORD=admin123
SEED_STAFF_PASSWORD=staff123

# Sarvam — speech-to-text for voice feedback (optional)
# https://dashboard.sarvam.ai/ — key must never be exposed to the browser
SARVAM_API_KEY=
# Optional: saaras:v3 (default) or saarika:v2.5
# SARVAM_STT_MODEL=saaras:v3
# For saaras:v3: transcribe | translate | verbatim | translit | codemix
# SARVAM_STT_MODE=codemix

# OpenRouter — AI analysis on each new feedback (optional)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional model (default: meta-llama/llama-3.1-8b-instruct). Browse: https://openrouter.ai/models
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
# Max service names embedded in AI prompt (names only, pipe-separated; saves tokens)
# OPENROUTER_PROMPT_MAX_SERVICES=40
# OPENROUTER_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional OpenRouter attribution headers
# OPENROUTER_HTTP_REFERER=https://feedback.mapims.edu.in
# OPENROUTER_APP_TITLE=MAPIMS Feedback System

# ---------------------------------------------------------------------------
# TMS (Ticket Management System) — optional; send/receive OFF by default
# ---------------------------------------------------------------------------
# Base URL of the TMS REST API (must include /api path used by the TMS server).
# TMS_API_BASE_URL=https://tms.mapims.edu.in/api

# Push feedback tickets to TMS (default off — tickets stay in Feedback only).
# TMS_OUTBOUND_ENABLED=false

# Pull routing services from TMS (default off — use local Services admin).
# TMS_CATALOG_ENABLED=false

# Optional: same value as TMS FEEDBACK_INGEST_TOKEN — required only if TMS sets that token.
# TMS_INGEST_TOKEN=

# TMS web app URL — links from Feedback admin (defaults to production host if unset).
# TMS_CLIENT_URL=https://tms.mapims.edu.in

# Optional: comma-separated origins allowed for /uploads CORS (otherwise *). Example:
# FEEDBACK_CORS_ORIGINS=https://tms.mapims.edu.in,https://feedback.mapims.edu.in
#
# If the browser gets HTTP 200 but audio won't play, check that /uploads is NOT served as SPA HTML:
# nginx must proxy /uploads/ to this Node process (see frontend/nginx.conf in this repo).

# ---------------------------------------------------------------------------
# EMR QueryBuilder — optional patient lookup by registration number (UHID)
# ---------------------------------------------------------------------------
# Browser never sees these values; only the Feedback API calls EMR.
# EMR_COOKIE=
# EMR_QUERY_BUILDER_URL=http://emr.mapims.edu.in/BB15SE/QueryBuilder/wsQueryBuilder.asmx/Getdataset1
# EMR_STR_CON=BB_CONSTR
# Date literals for report SPs: mdy = MM/DD/YYYY (typical US SQL Server), dmy = DD/MM/YYYY.
# EMR_SQL_DATE_ORDER=mdy
# Optional fixed reporting window (omit to use rolling lookback below).
# EMR_FRMDATE=
# EMR_TODATE=
# When the feedback UI leaves dates blank: from = today − N days, to = today (default 90).
# EMR_LOOKUP_LOOKBACK_DAYS=90
# Set to "true" to turn off /api/patient/lookup (form still allows “Name only”).
# EMR_PATIENT_LOOKUP_DISABLED=
